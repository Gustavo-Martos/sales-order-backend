{
  "compilerOptions": {
    "target": "es6",
    "module": "node16",
    "moduleResolution": "node16",
    "noImplicitAny": true,
    "strict": true,
    "strictNullChecks": true,
    "esModuleInterop": true,
    "outDir": "./dist",
    "rootDir": "./",
    "skipLibCheck": true,
    "paths": {
      "@models/*": ["./@cds-models/*"]
    }
  },
  "include": ["srv", "@cds-models"],
  "exclude": ["node_modules", "dist"]
}